# Banco de dados
DATABASE_URL=postgresql://pic:pic_secret@db:5432/pic

# Autenticação
JWT_SECRET=troque_em_producao
NEXTAUTH_SECRET=troque_em_producao
NEXTAUTH_URL=http://localhost:3000

# Ambiente
NODE_ENV=development

# LDAP / Active Directory
LDAP_URL=ldap://ldap.empresa.com
LDAP_BASE_DN=dc=empresa,dc=com
LDAP_BIND_USER=cn=admin,dc=empresa,dc=com
LDAP_BIND_PASSWORD=senha_ldap

# IA (escolha openai ou gemini)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# Email SMTP (compatível com Exchange Online / Office 365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=pic@empresa.com
SMTP_PASSWORD=senha_smtp
